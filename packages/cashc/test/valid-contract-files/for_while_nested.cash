contract ForWhileNested() {
    function spend() public {
        int sum = 0;

        for (int i = 0; i < 2; i = i + 1) {
            int j = 0;

            while (j < 2) {
                sum = sum + i + j;
                j = j + 1;
                console.log("sum:", sum, "i:", i, "j:", j);
            }
        }

        require(sum == 4);
    }
}
