contract WhileLoopNested() {
    function spend() public {
        int i = 0;
        int total = 0;

        while (i < 2) {
            int j = 0;

            while (j < 2) {
                total = total + 1;
                j = j + 1;
            }

            i = i + 1;
        }

        require(i == 2);
        require(total == 4);
    }
}
